# ─────────────────────────────────────────────────────────────────────────────
# OphtalmoScan — Environment variables template
# Copy to .env and fill in values.
# NEVER commit the real .env to git.
# In production: set these as server env vars, NOT a file next to the database.
# Items marked REQUIRED will refuse to boot if missing/invalid.
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED: Flask secret key ───────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=REPLACE_ME_WITH_A_RANDOM_STRING

# ── REQUIRED: cookie security (fail-closed, must be exactly 0 or 1) ──────────
# 1 = production (HTTPS only, Secure flag set). 0 = local/dev over HTTP.
# Startup refuses to boot if unset or not exactly 0 or 1.
SESSION_COOKIE_SECURE=1

# ── REQUIRED: field-level encryption key for patient PII ─────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# CRITICAL: back this up SEPARATELY from the database.
# Losing this key = losing all encrypted patient data forever.
FIELD_ENCRYPTION_KEY=REPLACE_ME_WITH_FERNET_KEY

# ── RECOMMENDED: separate key for escrowed DB backups ────────────────────────
# Lets backups be stored offsite without exposing the field-key.
# Falls back to FIELD_ENCRYPTION_KEY when unset.
BACKUP_ENCRYPTION_KEY=

# ── Database ─────────────────────────────────────────────────────────────────
# Default: SQLite at ./ophtalmo.db. For Postgres set DATABASE_URL instead.
# OPHTALMO_DB_PATH=/var/lib/ophtalmo/ophtalmo.db
# DATABASE_URL=postgresql://user:password@host:5432/ophtalmo

# ── Scheduler (daily email reminders, post-op gap checks, encrypted backups) ─
# Set to 1 on EXACTLY ONE worker / dedicated process.
# Multiple workers with ENABLE_SCHEDULER=1 will fire each cron job N times/day.
# Default (prod, unset): off — no scheduled jobs run.
ENABLE_SCHEDULER=0

# ── Rate limiting storage ────────────────────────────────────────────────────
# Production: point at Redis. memory:// is process-local and useless under
# multi-worker gunicorn (warning emitted at startup).
RATELIMIT_STORAGE_URI=redis://localhost:6379/0
# Set to 0 to disable rate limiting entirely (not recommended).
RATELIMIT_ENABLED=1

# ── Session idle timeout (minutes, default 60) ───────────────────────────────
SESSION_IDLE_TIMEOUT=60

# ── Error monitoring (optional) ──────────────────────────────────────────────
# Requires: pip install "sentry-sdk[flask]"
# SENTRY_DSN=https://xxxxx@xxx.ingest.sentry.io/xxxxx

# ── LLM providers (at least one required for AI features) ────────────────────
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# ── SMTP (patient emails, password resets, RDV confirmations) ────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=

# ── SMS (Twilio, optional) ───────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
DEFAULT_COUNTRY_CODE=+212

# ── Dev only ─────────────────────────────────────────────────────────────────
# FLASK_DEBUG=1
# FLASK_ENV=development
