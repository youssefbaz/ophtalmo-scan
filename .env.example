# ─────────────────────────────────────────────────────────────────────────────
# OphtalmoScan — Environment variables template
# Copy to .env and fill in values.
# NEVER commit the real .env to git.
# In production: set these as server env vars, NOT a file next to the database.
# ─────────────────────────────────────────────────────────────────────────────

# ── Flask secret key (REQUIRED) ───────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_ME_WITH_A_RANDOM_64_CHAR_HEX_STRING

# ── Field-level encryption key (REQUIRED for production) ─────────────────────
# Auto-generated on first run if absent.
# CRITICAL: back this up SEPARATELY from the database.
# Losing this key = losing all encrypted patient PII forever.
FIELD_ENCRYPTION_KEY=REPLACE_ME_WITH_FERNET_KEY

# ── Database ──────────────────────────────────────────────────────────────────
# Empty = SQLite (development). PostgreSQL URL = production multi-user.
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=

# ── AI providers ─────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your_key_here
GEMINI_API_KEY=your_gemini_key_here

# ── Email (optional — RDV reminders + password resets) ───────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre_email@gmail.com
SMTP_PASSWORD=votre_app_password_16_chars
EMAIL_FROM=votre_email@gmail.com

# ── Production flags ──────────────────────────────────────────────────────────
# Set SESSION_COOKIE_SECURE=1 only when HTTPS is active (Talisman enforces it).
SESSION_COOKIE_SECURE=0
FLASK_DEBUG=0
